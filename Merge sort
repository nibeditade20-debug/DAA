#include <stdio.h>

void merge(int a[], int l, int m, int h)
{
    int i = l, j = m+1, k = l;
    int temp[100];

    while(i <= m && j <= h)
    {
        if(a[i] < a[j])
            temp[k++] = a[i++];
        else
            temp[k++] = a[j++];
    }

    while(i <= m)
        temp[k++] = a[i++];

    while(j <= h)
        temp[k++] = a[j++];

    for(i = l; i <= h; i++)
        a[i] = temp[i];
}

void mergesort(int a[], int l, int h)
{
    if(l < h)
    {
        int m = (l + h) / 2;

        mergesort(a, l, m);
        mergesort(a, m+1, h);

        merge(a, l, m, h);
    }
}

int main()
{
    int a[100], n, i;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter elements:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    mergesort(a, 0, n-1);

    printf("Sorted array:\n");
    for(i = 0; i < n; i++)
        printf("%d ", a[i]);

    return 0;
}
