#include <stdio.h>

int max(int a, int b) {
    return (a > b) ? a : b;
}

int knapsack(int W, int wt[], int val[], int n) {
    int DP[n+1][W+1];
    int i, w;

    for(i = 0; i <= n; i++) {
        for(w = 0; w <= W; w++) {

            if(i == 0 || w == 0)
                DP[i][w] = 0;

            else if(wt[i-1] <= w)
                DP[i][w] = max(val[i-1] + DP[i-1][w - wt[i-1]],
                               DP[i-1][w]);

            else
                DP[i][w] = DP[i-1][w];
        }
    }

    return DP[n][W];
}

int main() {
    int val[] = {2, 4, 7, 10};
    int wt[]  = {1, 3, 5, 7};
    int W = 8;
    int n = 4;

    printf("Maximum Profit = %d", knapsack(W, wt, val, n));

    return 0;
}
