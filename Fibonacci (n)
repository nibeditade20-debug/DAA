#include <stdio.h>

int dp[100];

int fib(int n)
{
    if(n == 0)
        return 0;
    if(n == 1)
        return 1;

    if(dp[n] != -1)
        return dp[n];

    dp[n] = fib(n-1) + fib(n-2);
    return dp[n];
}

int main()
{
    int n;

    printf("Enter n: ");
    scanf("%d", &n);

    // initialize dp array
    for(int i = 0; i <= n; i++)
        dp[i] = -1;

    printf("Fibonacci series:\n");
    for(int i = 0; i < n; i++)
        printf("%d ", fib(i));

    return 0;
}
